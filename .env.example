# Copy to `.env` in this folder if you want defaults without exporting in your shell.
# Values here are ignored if the same variable is already set in the real environment.

# Optional: full suit list as one JSON array (when set, suits.json is not read).
# Must stay on one line. Example — two suits only:
# CARDSHEET_SUITS=[{"name":"hearts","path":"icons/heart.png","color":[255,0,0]},{"name":"spades","path":"icons/spade.png","color":[200,200,200]}]

# Optional: path to JSON file (default: suits.json next to suits_loader.py)
# CARDSHEET_SUITS_JSON=suits.json
